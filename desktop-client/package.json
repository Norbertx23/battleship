{
  "name": "battleship-client",
  "version": "1.0.0",
  "description": "Battleship Thin Client for Homelab",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.norbertswistak.battleship",
    "productName": "Battleship",
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.games",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "author": "Norbert Swistak",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}